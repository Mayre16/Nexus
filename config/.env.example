# ====================================================================
# ADESA NEXUS - Plantilla de variables de entorno
# --------------------------------------------------------------------
# 1. Copia este archivo a "config/.env" (o ".env" en la raíz del backend).
# 2. Rellena con valores REALES solo en el servidor (nunca en el repo).
# 3. En cPanel asegura permisos 600 y un .htaccess que devuelva 403
#    para .env, logs/ y backups/ (ver SECURITY-NEXUS.md).
# 4. Usa credenciales DISTINTAS por entorno (dev / staging / prod).
# ====================================================================

# ---------- Entorno y servidor ----------
NODE_ENV=development                # development | staging | production
APP_NAME=ADESA Nexus
PORT=3000
# Dominios permitidos por CORS (allowlist explícita, separados por coma).
# NUNCA usar "*" junto con cookies de credenciales.
CORS_ALLOWED_ORIGINS=https://nexus.adesa.com.do,https://deportes.adesa.com.do
# Cuando NODE_ENV=production, las cookies se emiten Secure + SameSite=Strict.
COOKIE_DOMAIN=.adesa.com.do

# ---------- Base de datos MySQL (cPanel) ----------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=adesa_nexus
DB_USER=nexus_app                   # Usuario con MÍNIMO privilegio (solo este schema)
DB_PASSWORD=                        # <-- SECRETO
DB_CONNECTION_LIMIT=10
# multipleStatements SIEMPRE en false (anti SQLi por apilamiento).

# ---------- JWT (autenticación en cookies HTTPOnly) ----------
# Genera secretos de 64+ bytes:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=                  # <-- SECRETO (firma del access token)
JWT_REFRESH_SECRET=                 # <-- SECRETO (firma del refresh token, DISTINTO al anterior)
JWT_ACCESS_TTL=15m                  # Access token corto
JWT_REFRESH_TTL=7d                  # Refresh token rotativo
JWT_ISSUER=adesa-nexus
JWT_AUDIENCE=adesa-nexus-clients

# ---------- Cifrado de datos sensibles en reposo (AES-256-GCM) ----------
# Clave maestra de 32 bytes en HEX (64 caracteres):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Protege: credenciales de conexión a clientes, VPNs, tokens de servidores.
# Si se rota, hay que re-cifrar los registros existentes (ver crypto.js).
DATA_ENCRYPTION_KEY=                # <-- SECRETO (32 bytes hex)

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=900000         # Ventana general (15 min)
RATE_LIMIT_MAX=300                  # Máx. peticiones por ventana (general)
LOGIN_RATE_LIMIT_MAX=5              # Máx. intentos de login por ventana (anti fuerza bruta)

# ---------- Tokens de dispositivo Nexus Tracker (app "badboy" C#) ----------
# El endpoint /api/performance/log NO usa cookies; valida un token de dispositivo.
TRACKER_DEVICE_SHARED_SECRET=       # <-- SECRETO (HMAC para firmar reportes del agente)

# ---------- Correo / IMAP (Nexus Desk & Mail AI) ----------
# Buzones visibles por división (correo de recepción de tickets)
DESK_MAIL_ENERGIA=soporte@adesa.com.do
DESK_MAIL_DEPORTES=info@labicicleteria.do
DESK_IMAP_ENABLED=false                    # true en prod cuando haya contraseña IMAP
DESK_IMAP_POLL_MINUTES=3
IMAP_HOST=mail.adesa.com.do
IMAP_PORT=993
IMAP_TLS=true
# Credenciales por buzón (mismo servidor energía; deportes suele ser otro host)
IMAP_ENERGIA_USER=soporte@adesa.com.do
IMAP_ENERGIA_PASSWORD=                     # <-- SECRETO
IMAP_DEPORTES_HOST=mail.labicicleteria.do
IMAP_DEPORTES_USER=info@labicicleteria.do
IMAP_DEPORTES_PASSWORD=                    # <-- SECRETO
SMTP_HOST=mail.adesa.com.do
SMTP_PORT=465
SMTP_SECURE=true
SMTP_ENERGIA_USER=soporte@adesa.com.do
SMTP_ENERGIA_PASSWORD=                     # <-- SECRETO
SMTP_DEPORTES_HOST=mail.labicicleteria.do
SMTP_DEPORTES_USER=info@labicicleteria.do
SMTP_DEPORTES_PASSWORD=                    # <-- SECRETO

# ---------- Portal de autoservicio cliente ----------
# Invitaciones y notificaciones usan SMTP anterior. En producción:
#   DESK_IMAP_ENABLED=true  → correos a soporte@ crean/actualizan tickets automáticamente
#   NEXUS_PUBLIC_URL=https://nexus.adesa.com.do  → enlaces correctos en invitaciones

# ---------- Pasarelas de pago (Nexus Store / Hub) ----------
STRIPE_SECRET_KEY=                  # <-- SECRETO
STRIPE_WEBHOOK_SECRET=              # <-- SECRETO (verificación de firma de webhook)
CARDNET_MERCHANT_ID=
CARDNET_API_KEY=                    # <-- SECRETO
AZUL_AUTH1=                         # <-- SECRETO
AZUL_AUTH2=                         # <-- SECRETO

# ---------- Integraciones externas ----------
# ERP ADM (API pull/push, sin webhooks)
ADM_API_URL=https://
ADM_API_USER=
ADM_API_PASSWORD=                   # <-- SECRETO

# ---------- Módulo iERP (ERP addon dentro de Nexus, estilo Odoo) ----------
# Módulo contable (UI integrada en /ierp.html | API proxy /api/ierp)
# BD UNIFICADA: iERP usa la MISMA MySQL que Nexus (DB_* arriba). No PostgreSQL aparte.
IERP_ENABLED=true
IERP_API_URL=http://127.0.0.1:3001
IERP_UI_URL=http://127.0.0.1:3002
# Clave compartida iERP ↔ Nexus (leads, integraciones)
IERP_NEXUS_API_KEY=
# Usuario de servicio iERP para la UI nativa (mismo tenant que Leads/Almacén)
IERP_BFF_EMAIL=admin@demo.local
IERP_BFF_PASSWORD=
NEXUS_PUBLIC_URL=http://localhost:3000
MODULES_DISABLED=

# Catálogo Schneider Electric
SCHNEIDER_API_URL=https://
SCHNEIDER_API_KEY=                  # <-- SECRETO
# API de precios de la bicicletería (ADESA Deportes - cPanel propio)
DEPORTES_API_URL=https://
DEPORTES_API_KEY=                   # <-- SECRETO
# EasyMetering Energify — Nexus Grid (portal ADESA)
EASYMETERING_BASE_URL=https://adesa.cloud.easymetering.com
EASYMETERING_LOGIN_URL=https://adesa.cloud.easymetering.com/login?next=/
EASYMETERING_USER=
EASYMETERING_PASSWORD=              # <-- SECRETO
# Alternativa: pegar tokens JWT desde DevTools → Application → localStorage → authTokens
EASYMETERING_ACCESS_TOKEN=
EASYMETERING_REFRESH_TOKEN=
# Solo si usas login API directo (requiere token reCAPTCHA del navegador)
EASYMETERING_RECAPTCHA_TOKEN=
# auto = API si hay refresh token, si no navegador | api | browser
EASYMETERING_SYNC_MODE=auto

# Accuenergy AcuRev 2100 (medidor / API cloud)
ACUREV2100_API_TOKEN=               # <-- SECRETO

# ---------- UniFi Site Manager (router UCG Max / clientes WiFi) ----------
# API key: unifi.ui.com → Settings → API Keys
#   ✓ UniFi Applications → Network → sitio ADESA
# NO hace falta login en https://10.0.0.163 — el proxy cloud alcanza la consola.
UNIFI_SITE_MANAGER_ENABLED=true
UNIFI_SITE_MANAGER_BASE_URL=https://api.ui.com/v1
UNIFI_SITE_MANAGER_API_KEY=           # <-- SECRETO (X-API-KEY)
UNIFI_SITE_ID=                        # vacío = auto; o UUID del sitio
UNIFI_CONSOLE_ID=                     # vacío = auto; ID en unifi.ui.com/consoles/{AQUI}/...

# Opcional: API local solo si tienes key de Integrations en el UCG (requiere acceso al console)
UNIFI_LOCAL_BASE_URL=https://10.0.0.163/proxy/network/integration/v1
UNIFI_LOCAL_API_KEY=
UNIFI_LOCAL_SITE_ID=
UNIFI_LOCAL_INSECURE_TLS=true

# ---------- Almacenamiento de uploads (cierre de tickets / OT) ----------
# Directorio FUERA del webroot. Se valida que toda ruta quede confinada aquí.
UPLOAD_DIR=./storage/uploads
UPLOAD_MAX_BYTES=10485760           # 10 MB por archivo
