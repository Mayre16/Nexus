# =============================================================================
# Variables de entorno para el sistema WMS
# Copiar este archivo a .env y configurar los valores reales
# =============================================================================

# --- Flask ---
FLASK_ENV=production
SECRET_KEY=genera-una-clave-secreta-aleatoria-aqui

# --- Base de datos (MySQL en producción) ---
DATABASE_URL=mysql+pymysql://usuario:password@host:3306/nombre_db?charset=utf8mb4
DB_USE_NULLPOOL=false

# --- ADM Cloud API ---
ADM_API_BASE=https://api.admcloud.net/api/
ADM_EMAIL=tu-email@dominio.com
ADM_PASSWORD=tu-password-aqui
ADM_APPID=tu-appid-guid
ADM_COMPANY=tu-company-guid
ADM_ROLE=Administradores

# --- CORS ---
CORS_ALLOWED_ORIGIN=https://wms.tudominio.com

# --- Email (SMTP) ---
SMTP_HOST=mail.tudominio.com
SMTP_PORT=465
SMTP_USER=notificaciones@tudominio.com
SMTP_PASS=tu-smtp-password

# --- Cron / Auto-sincronización ---
CRON_TOKEN=genera-un-token-aleatorio-aqui

# --- Abastecimiento (módulo admin: mín/máx por ubicación ADM) ---
# Opcional: GUID exacto de la ubicación (recomendado en producción).
# ABASTECIMIENTO_LOCATION_ID=
# Si no se define, se busca por nombre en sync_locations_status:
ABASTECIMIENTO_LOCATION_NAME=Mirador Sur

# --- Feature flags ---
FEATURE_MUST_CHANGE_PASSWORD=false
FEATURE_AUDIT_LOG=false
FEATURE_RATE_LIMIT_LOGIN=false
