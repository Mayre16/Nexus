<Window x:Class="MonitorSuite.Admin.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ADESA MonitorSuite · Acceso"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="440"
        Height="560"
        Background="{StaticResource AdesaBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Cabecera roja ADESA -->
        <Border Background="{StaticResource AdesaRedBrush}" Padding="24,20">
            <StackPanel>
                <TextBlock Text="ADESA MonitorSuite" Foreground="White" FontSize="22" FontWeight="Bold" />
                <TextBlock Text="Panel local de monitoreo · BadBoy" Foreground="{StaticResource AdesaGoldBrush}" FontSize="12" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="24" Padding="24" Background="White" CornerRadius="8"
                BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Credenciales de administrador" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource AdesaInkBrush}" Grid.Row="0" />

                <StackPanel Margin="0,20,0,0" Grid.Row="1">
                    <TextBlock Text="Usuario" FontWeight="SemiBold" />
                    <TextBox Margin="0,6,0,0" Padding="8"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,16,0,0" Grid.Row="2">
                    <TextBlock Text="Contraseña" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,6,0,0" Padding="8"
                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                 KeyDown="PasswordBox_OnKeyDown" />
                    <TextBlock Margin="0,6,0,0" Foreground="#888" FontSize="11"
                               Text="Por defecto: admin / ChangeMe!2025" />
                </StackPanel>

                <TextBlock Grid.Row="3" Margin="0,16,0,0" Foreground="#666" FontSize="11" TextWrapping="Wrap"
                           Text="OTP no requerido. Use admin local o Microsoft (MFA) si está configurado." />

                <Border Grid.Row="4" Margin="0,12,0,0" Padding="10" CornerRadius="6"
                        Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Estado del agente (background)" FontWeight="SemiBold" FontSize="11" Foreground="#166534" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding AgentStatusText}" TextWrapping="Wrap"
                                   FontSize="11" Foreground="#15803D" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="5" VerticalAlignment="Bottom">
                    <TextBlock Foreground="Red" Text="{Binding ErrorMessage}" Margin="0,0,0,8" TextWrapping="Wrap" />
                    <Button Content="Iniciar sesión con Microsoft (MFA)"
                            Command="{Binding MicrosoftLoginCommand}"
                            Visibility="{Binding MicrosoftLoginAvailable, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource AdesaSecondaryButton}" Padding="16,8" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Margin="0,0,8,0" Padding="16,8" Click="Cancel_Click"
                                Style="{StaticResource AdesaSecondaryButton}" />
                        <Button Padding="16,8"
                                Command="{Binding LoginCommand}"
                                IsDefault="True"
                                Style="{StaticResource AdesaPrimaryButton}">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Ingresar" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                                <Setter Property="Text" Value="Conectando…" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
