<Window x:Class="MonitorSuite.Admin.Views.MachineProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Perfil de este equipo"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="{StaticResource AdesaBackgroundBrush}">
    <Border Margin="24" Padding="24" Background="White" CornerRadius="8"
            BorderBrush="{StaticResource AdesaRedBrush}" BorderThickness="0,4,0,0">
        <StackPanel MinWidth="420">
            <TextBlock Text="Identificación del empleado en este PC"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource AdesaInkBrush}" />
            <TextBlock Margin="0,8,0,16" TextWrapping="Wrap" Foreground="#666"
                       Text="Asigna el nombre que verás en gráficos, reportes y Nexus Tracker. Cada computadora puede tener su propio perfil." />

            <TextBlock Text="Equipo (automático)" FontWeight="SemiBold" />
            <TextBox Margin="0,4,0,12" IsReadOnly="True" Background="#F5F5F5"
                     Text="{Binding MachineName}" />

            <TextBlock Text="Usuario Windows (automático)" FontWeight="SemiBold" />
            <TextBox Margin="0,4,0,12" IsReadOnly="True" Background="#F5F5F5"
                     Text="{Binding WindowsUser}" />

            <TextBlock Text="Nombre del empleado *" FontWeight="SemiBold" />
            <TextBox Margin="0,4,0,12"
                     Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Ej: Martha Valenzuela" />

            <TextBlock Text="Correo corporativo" FontWeight="SemiBold" />
            <TextBox Margin="0,4,0,12"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Ej: martha@adesa.com.do" />

            <TextBlock Text="División (energia / deportes / ambas)" FontWeight="SemiBold" />
            <TextBox Margin="0,4,0,16"
                     Text="{Binding Division, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Margin="0,0,8,0" Padding="16,8"
                        IsCancel="True" Style="{StaticResource AdesaSecondaryButton}" />
                <Button Content="Guardar" Padding="16,8" IsDefault="True"
                        Click="Save_Click" Style="{StaticResource AdesaPrimaryButton}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
